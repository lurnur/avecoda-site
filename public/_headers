# Cloudflare Pages reads this file from the build output (dist/_headers).
# Rules are applied top-to-bottom; later matches add to earlier ones.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Security headers for every response
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # No client JS ships today (only inline JSON-LD, which is not executed).
  # Styles are 'unsafe-inline' because Astro emits inline style attributes.
  # Fonts are self-hosted, so everything is same-origin ('self').
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' mailto:; object-src 'none'

# Fingerprinted assets (Astro hashes the filename) — cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts — content-addressed by us, safe to cache forever
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
