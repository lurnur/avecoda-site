---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroDataFlow from "../components/HeroDataFlow.astro";

// ─────────────────────────────────────────────────────────────────────────────
// index v3 — marketing-best-practice restructure of v2.
//
// What changed and why:
//  • Narrative order now follows a standard homepage arc: hook (hero) → proof
//    (live diagram) → category definition (what it IS) → benefit (a better day
//    per seat) → differentiation (vs. the converged suites) → quantified value
//    → CTA. v2 led with benefits before ever defining the product.
//  • Alignment fixes: the 5 "seat" outcomes are now full-width role rows instead
//    of a 3-col grid (which orphaned 2 cards), and the 5 differentiators are a
//    balanced before/after comparison instead of a 2-col grid (which orphaned 1).
//  • Section rhythm: alternating full-bleed soft bands separate sections, so the
//    page reads as distinct chapters rather than one continuous column.
//  • Scannability: each card/row leads with a short, bold takeaway.
//
// Content source unchanged from v2 (project knowledge "Neolect Website - Content"
// → docs/Neolect - Overview.md). Figures are independent research (Salesforce,
// Forrester, Gartner); the compounded revenue projection is illustrative and
// validated with the FDE team in the first 90 days.
// ─────────────────────────────────────────────────────────────────────────────

// ── What Neolect is (three defining properties) ─────────────────────────────
const defining = [
  {
    label: "Property 01",
    lead: "One canonical model.",
    title: "It unifies your stack into clean, reconciled data",
    body: "Communication, enrichment, and CRM data flow through an open integration layer into a single working model — so the rest of Neolect reads from reconciled data, not sparse CRM fields.",
  },
  {
    label: "Property 02",
    lead: "Governed automation.",
    title: "Agents propose, humans approve, then it writes back",
    body: "Deterministic blocks drive the mechanical RevOps work; scoped, sandboxed agents add judgment on top. Nothing writes back until a person approves it — and every step is audited and reversible.",
  },
  {
    label: "Property 03",
    lead: "Free of the deal model.",
    title: "It shapes around the unit that matters to your motion",
    body: "A spreadsheet-inspired canvas lets you build around the account, product, or territory your motion actually runs on — instead of forcing everything through the Opportunity object.",
  },
];

// ── A better day in every seat (outcomes by role) ───────────────────────────
const seats = [
  {
    seat: "The rep",
    job: "Starts the day knowing exactly who to call",
    body: "A ranked list of who to contact and why — the champion whose tone shifted yesterday, the inbound that matches three prior wins — each name carrying a reason and a drafted next move. Meetings, emails, and calls are captured at the source; the CRM updates itself. The rep just sells.",
  },
  {
    seat: "The manager",
    job: "Coaches the deal, not the spreadsheet",
    body: "Every deal arrives with the evidence behind it. Deals that look fine in the CRM but have stalled in substance surface with specific reasons, and a coaching feed flags the moments worth listening to. Monday shifts from \"what's the latest\" to \"here's what we should do about it.\"",
  },
  {
    seat: "The CRO",
    job: "Commits a number they can defend",
    body: "A forecast grounded in the actual journeys deals are taking, not stage probability times a rep's gut. When the number moves, the system attributes it — this deal slipped because the champion went quiet on the 14th — and the parallel spreadsheet retires.",
  },
  {
    seat: "RevOps",
    job: "Designs the motion instead of plumbing data",
    body: "The people with the questions get answers without filing a ticket. Hygiene maintains itself because capture happens at the source, so the team's time moves from data plumbing to designing the motion.",
  },
  {
    seat: "Customer success",
    job: "Continues the relationship, never rediscovers it",
    body: "At handoff, CS inherits the full journey — buying committee, competitors and why each lost, objections handled, commitments made. The first conversation after close is a continuation, and renewal risk surfaces early through the same system.",
  },
];

// ── How it's different — converged suites vs. Neolect ───────────────────────
const suiteApproach = [
  "Adopt one vendor's system wholesale — migrate everything in an 18-month project.",
  "Point AI agents at raw, unreconciled CRM fields and hope.",
  "Force every workflow through the Opportunity object.",
  "Let loose agents write back to your systems on their own.",
  "Accept the control model the platform imposes on you.",
];
const neolectApproach = [
  "Sit next to your CRM and orchestrate across the tools you already run — no rip-and-replace.",
  "Agents reason only over typed evidence the workflows have already assembled and cleaned.",
  "A free-form canvas models work around accounts, products, or territories.",
  "Agents are scoped, sandboxed, and propose; humans approve, and every write-back is reversible.",
  "You define the structure and hold the controls — Neolect gives you the controls, not the cage.",
];

// ── The value, in numbers ───────────────────────────────────────────────────
const stats = [
  {
    value: "8–12",
    unit: "hrs",
    tone: "teal",
    label:
      "of selling time returned per rep, per week, through at-source capture and agent-drafted next moves. For a 50-rep team, that's 10+ reps of capacity — without a hire.",
    source: "Baseline: reps sell ~28% of the week (Salesforce State of Sales).",
  },
  {
    value: "+3",
    unit: "pts",
    tone: "teal-green",
    label:
      "of win rate, as slipping deals are caught early. Top performers sell 34% of their time versus 23% for the bottom — that gap closes when risk surfaces in time to act.",
    source: "Performance gap: Forrester.",
  },
  {
    value: "±5",
    unit: "%",
    tone: "teal-blue",
    label:
      "forecast accuracy, tightened from a typical ±10%. Grounded in committee depth, engagement trend, and evidence of intent — a number the CRO can defend.",
    source: "Baseline: 43% of orgs miss forecast by >10% (Gartner).",
  },
];
---

<BaseLayout
  title="Neolect — The revenue orchestration platform that sits next to your CRM"
  description="Neolect is the connected, intelligent workspace that runs alongside your CRM"
>
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <!-- ── Live data-flow embed (full-bleed) ────────────────────────────── -->
  <div class="hero-embed-bleed">
    <HeroDataFlow />
  </div>

  <!-- ── 1 · What Neolect is ──────────────────────────────────────────── -->
  <section id="what" aria-labelledby="what-h">
    <div class="section-head prose">
      <span class="eyebrow teal">What Neolect is</span>
      <h2 id="what-h">The connected, intelligent workspace around your CRM.</h2>
      <p>
        The CRM stays the system of record. Neolect is the layer where revenue
        work is coordinated, automated, and acted on — the surface every role
        works from, day to day. Three things define it.
      </p>
    </div>
    <div class="card-grid cols-3">
      {defining.map((d) => (
        <article class="card accent">
          <div class="card-eyebrow">{d.label}</div>
          <h3><span class="lead-in">{d.lead}</span> {d.title}</h3>
          <p>{d.body}</p>
        </article>
      ))}
    </div>
    <div class="callout">
      <p class="lead" style="margin: 0;">
        A defining detail: Neolect stores the
        <span class="hl">full journey of every deal</span> — every state change,
        signal, and touch over time — not just the latest snapshot. The journey
        is the data asset: a longitudinal, first-party dataset that grounds the
        forecast and travels intact to customer success at handoff.
      </p>
    </div>
  </section>

  <!-- ── 2 · A better day in every seat ───────────────────────────────── -->
  <section class="band" aria-labelledby="seats-h">
    <div class="section-head prose">
      <span class="eyebrow">What it does for you</span>
      <h2 id="seats-h">One intelligence layer. A better day in every seat.</h2>
      <p>
        Neolect doesn't add another dashboard to check. It changes what each
        person on the revenue team starts the day with — because the same
        canonical model is composed into a different surface for every job.
      </p>
    </div>
    <div class="seats">
      {seats.map((o) => (
        <article class="seat">
          <div class="seat-role">
            <span class="seat-label">{o.seat}</span>
          </div>
          <div class="seat-text">
            <h3>{o.job}</h3>
            <p>{o.body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ── 3 · How it's different ───────────────────────────────────────── -->
  <section aria-labelledby="diff-h">
    <div class="section-head prose">
      <span class="eyebrow warm">How it's different</span>
      <h2 id="diff-h">Orchestrate across your stack — without giving up what works.</h2>
      <p>
        The converged revenue suites orchestrate by becoming the system you
        adopt wholesale. Neolect takes the opposite posture: it sits next to
        your CRM and works across the tools you already have.
      </p>
    </div>
    <div class="compare">
      <div class="compare-col before">
        <h3>The converged-suite approach</h3>
        <ul>
          {suiteApproach.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
      <div class="compare-col after">
        <h3>The Neolect approach</h3>
        <ul>
          {neolectApproach.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── 4 · The value, in numbers ────────────────────────────────────── -->
  <section class="band" aria-labelledby="value-h">
    <div class="section-head prose">
      <span class="eyebrow teal">The value, in numbers</span>
      <h2 id="value-h">Three numbers every revenue leader already tracks.</h2>
      <p>
        The baselines below are independent research. The improvements are
        Neolect's projections for a team of this size — validated against your
        motion in the first 90 days, not carried over from the reports.
      </p>
    </div>

    <div class="stats">
      {stats.map((s) => (
        <div class="stat">
          <span class={`stat-num ${s.tone}`}>
            {s.value}<span class="stat-unit">{s.unit}</span>
          </span>
          <span class="stat-label">{s.label}</span>
          <span class="stat-source">{s.source}</span>
        </div>
      ))}
    </div>

    <p class="punchline">
      For a 100-rep organization on a $100M plan, that points to
      <span class="hl">$10–15M</span> in additional, more predictable annual
      revenue — against an investment that's a fraction of what's already spent
      on the CRM stack.
    </p>
    <p class="punchline-note">
      The compounded revenue projection is illustrative for a team of this size;
      actual outcomes are validated against your motion in the first 90 days with
      the forward-deployed team.
    </p>
  </section>

  <!-- ── Final CTA ────────────────────────────────────────────────────── -->
  <section>
    <div class="cta-banner">
      <span class="eyebrow">Get started</span>
      <h2>Get the value you paid for from the CRM you already own.</h2>
      <p class="lead">
        No rip-and-replace. No migration. No 18-month implementation. Neolect
        runs alongside your CRM and writes back to it — you add a capability,
        not undertake a project.
      </p>
      <div class="cta-group">
        <a href="/contact" class="btn btn-primary">
          Request a walkthrough <span class="arr" aria-hidden="true">→</span>
        </a>
        <a href="/resources" class="btn btn-ghost">How we deploy</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Full-bleed band so the animated diagram spans the viewport, breaking out
     of the centered .container that wraps page content in BaseLayout. */
  .hero-embed-bleed {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    margin-top: 0;
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  /* Small reassurance line under the hero CTAs. */
  .hero-note {
    margin-top: var(--space-3);
    color: var(--color-muted);
    font-size: 0.875rem;
    max-width: 48ch;
  }

  /* ── Full-bleed soft band: paints a viewport-wide tinted background behind a
     section without extra wrappers, giving the page alternating rhythm. ── */
  .band {
    position: relative;
    isolation: isolate;
  }
  .band::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
    background: var(--color-bg-soft);
    border-block: 1px solid var(--color-border);
    z-index: -1;
  }
  /* Bands keep their own top padding even when they follow another section
     (overrides the global `section + section { padding-top: 0 }`). */
  section + .band {
    padding-top: var(--space-5);
  }

  /* ── Short bold takeaway that leads each property card ── */
  .lead-in {
    color: var(--color-accent);
  }

  /* ── Seat rows: role label + outcome, full width so 5 items never orphan ── */
  .seats {
    margin-top: var(--space-4);
  }
  .seat {
    display: grid;
    grid-template-columns: 13rem 1fr;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
  }
  .seat:first-child {
    border-top: none;
  }
  .seat-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .seat h3 {
    margin: 0 0 var(--space-2);
  }
  .seat p {
    margin: 0;
    font-size: 0.9375rem;
  }
  @media (max-width: 720px) {
    .seat {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }

  .stat-unit {
    font-size: 0.5em;
    margin-left: 0.15em;
    letter-spacing: 0;
  }

  /* ── Numbers punchline: a quiet, centered statement on the soft band ── */
  .punchline {
    max-width: 60ch;
    margin: var(--space-4) auto 0;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.5vw + 1rem, 1.875rem);
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--color-fg);
  }
  .punchline-note {
    max-width: 60ch;
    margin: var(--space-3) auto 0;
    text-align: center;
    color: var(--color-muted);
    font-size: 0.8125rem;
    font-style: italic;
  }
</style>
