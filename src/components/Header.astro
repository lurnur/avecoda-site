---
type NavItem = { href: string; label: string };

const nav: NavItem[] = [
  { href: "/", label: "Overview" },
  { href: "/product", label: "Product" },
  { href: "/resources", label: "Resources" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCurrent = (href: string) => path === href;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-current={path === "/" ? "page" : undefined}>
      <span class="brand-mark" aria-hidden="true"></span>Neolect
    </a>
    <nav aria-label="Primary">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a href="/contact" class="btn btn-primary header-cta">
      Request a walkthrough
      <span class="arr" aria-hidden="true">→</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 88%, transparent);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-3);
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    color: var(--color-fg);
    text-decoration: none;
  }
  nav {
    margin-inline: auto;
  }
  nav > ul {
    list-style: none;
    display: flex;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  nav a,
  nav .dropdown-trigger {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-fg-soft);
    text-decoration: none;
    position: relative;
    padding-block: 0.25rem;
    transition: color 150ms ease;
  }
  nav a:hover,
  nav .dropdown-trigger:hover {
    color: var(--color-accent);
  }
  nav a[aria-current="page"],
  nav .dropdown-trigger[data-current="true"] {
    color: var(--color-accent);
  }
  nav a[aria-current="page"]::after,
  nav .dropdown-trigger[data-current="true"]::after {
    content: "";
    position: absolute;
    inset: auto 0 -2px 0;
    height: 2px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .has-dropdown {
    position: relative;
  }
  .dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: 0;
    cursor: pointer;
    line-height: inherit;
  }
  .caret {
    font-size: 0.7em;
    transition: transform 150ms ease;
  }
  .has-dropdown:hover .caret,
  .has-dropdown:focus-within .caret,
  .dropdown-trigger[aria-expanded="true"] .caret {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    list-style: none;
    margin: 0;
    padding: var(--space-2);
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 12rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    box-shadow: 0 12px 28px -12px rgb(0 0 0 / 0.18);
    display: grid;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 120ms ease, visibility 120ms ease;
  }
  .has-dropdown:hover .dropdown-menu,
  .has-dropdown:focus-within .dropdown-menu,
  .dropdown-trigger[aria-expanded="true"] + .dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .dropdown-menu a {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.4rem;
    white-space: nowrap;
  }
  .dropdown-menu a:hover {
    background: var(--color-bg-soft);
    color: var(--color-accent);
  }
  .dropdown-menu a[aria-current="page"] {
    background: var(--color-bg-soft);
    color: var(--color-accent);
  }
  .dropdown-menu a[aria-current="page"]::after {
    content: none;
  }

  .header-cta {
    padding: 0.55rem 1rem;
    font-size: 0.875rem;
  }
  @media (max-width: 720px) {
    .header-cta {
      display: none;
    }
    nav {
      margin-inline: 0;
    }
    .dropdown-menu {
      left: 0;
      transform: none;
    }
  }
</style>
