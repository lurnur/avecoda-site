---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="contact">
      Questions? <a href="mailto:prasanth@neupage.com">prasanth@neupage.com</a>
    </p>
    <p class="copyright">© {year} Avecoda. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-6);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-4);
    flex-wrap: wrap;
  }
  .footer-inner p {
    margin: 0;
    color: var(--color-muted);
  }
  .site-footer a {
    color: var(--color-accent);
  }
</style>
