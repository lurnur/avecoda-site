<script is:inline>
/* Pause the loop whenever it scrolls off-screen (saves CPU/battery). */
(function(){
  var heroes = document.querySelectorAll('[data-nl-hero]');
  if(!('IntersectionObserver' in window)){ return; }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      e.target.classList.toggle('nl-paused', !e.isIntersecting);
    });
  }, { threshold: 0 });
  heroes.forEach(function(h){ io.observe(h); });
})();
</script>
